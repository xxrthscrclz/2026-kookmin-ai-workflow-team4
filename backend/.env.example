# 백엔드 환경변수 예시 — 실제 값은 .env에 두고 커밋하지 않는다.

# SQLite 파일 경로 (prisma/ 기준 상대경로)
DATABASE_URL="file:./dev.db"

# API 서버 포트 (FE의 VITE_SERVER_URL 가정과 일치)
PORT=8080

# CORS 허용 오리진 (Vite dev 서버)
CORS_ORIGIN="http://localhost:5173"

# LLM (선택). 키가 없으면 자동으로 mock 모드로 동작한다.
# OpenAI 호환 엔드포인트를 사용한다.
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
