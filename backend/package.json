{
  "name": "meeting-hub-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "회의 지식 허브 백엔드 API 서버 (Express + Prisma + SQLite)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:be2": "tsx scripts/smoke-be2.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
